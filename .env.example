# =========================
# IIS Game Portal
# =========================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_ALLOWED_EMAILS=admin@example.com

# Server-only
SUPABASE_SERVICE_ROLE_KEY=
CORE_ENGINE_URL=http://localhost:8000
# Required in production (BFF fail-fast if missing unless Authorization header is explicitly provided)
CORE_ENGINE_API_TOKEN=
FEATURED_GAME_SLUG=
IIS_DEMO_PREVIEW=0
# Ops console v2 collaboration room (set 0/false/off to rollback legacy board)
OPS_COLLAB_ROOM_V2=1
# Temporary rollback flag for legacy games that require same-origin iframe
LEGACY_GAME_SANDBOX=0
# Optional: comma-separated game ids/slugs that still require legacy sandbox
# Example: LEGACY_GAME_SANDBOX_ALLOWLIST=demo-neon-drift,1b7e...
LEGACY_GAME_SANDBOX_ALLOWLIST=
